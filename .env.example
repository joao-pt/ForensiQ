# ForensiQ — Template de Variáveis de Ambiente
# Copiar para .env e preencher com valores reais. Nunca commitar .env.

# --- Base de dados PostgreSQL (Neon.tech em produção) ---
DATABASE_URL=postgresql://user:password@host:5432/database_name?sslmode=require

# --- Django ---
SECRET_KEY=changeme-generate-via-django.core.management.utils.get_random_secret_key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- JWT (SimpleJWT) ---
# Chave usada para assinar JWTs. OBRIGATÓRIA em produção (DEBUG=False): o
# settings.py falha o arranque se faltar, para não acoplar a assinatura de
# tokens ao SECRET_KEY (rodar/expor um não compromete o outro). Em
# desenvolvimento/testes, se vazia, cai para o SECRET_KEY por conveniência.
JWT_SIGNING_KEY=
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- Django Admin ---
# Prefixo aleatório em produção (ex.: painel-fq-8x7k). Por defeito 'admin'.
ADMIN_URL_PREFIX=admin

# --- Trusted proxies para AuditLog ---
# CSV de IPs ou redes CIDR cujos cabeçalhos X-Forwarded-For/X-Real-IP podem ser
# usados como fonte de IP do cliente. Em Fly.io, são as redes internas da
# plataforma. Em desenvolvimento local, deixar vazio ou usar 127.0.0.1.
TRUSTED_PROXIES=127.0.0.1,::1

# --- Lookup externo IMEI (opcional) ---
# Token para imeidb.xyz. Se vazio, o endpoint /api/evidences/lookup/imei/
# responde 503 e o frontend faz fallback gracioso.
IMEIDB_API_TOKEN=

# --- Produção (Fly.io) ---
# Descomentar e ajustar para ambiente de produção:
# DEBUG=False
# ALLOWED_HOSTS=forensiq.pt,www.forensiq.pt,forensiq.fly.dev
# ADMIN_URL_PREFIX=painel-fq-8x7k
# TRUSTED_PROXIES=10.0.0.0/8,fc00::/7  # redes internas Fly.io
