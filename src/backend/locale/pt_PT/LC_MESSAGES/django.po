# ForensiQ — Catálogo de tradução pt-PT (overrides de bibliotecas).
#
# Este catálogo NÃO traduz strings da própria aplicação (essas são escritas
# diretamente em pt-PT no código/templates). Serve para localizar mensagens
# de bibliotecas de terceiros que, com LANGUAGE_CODE='pt-pt':
#   * SimpleJWT — não distribui catálogo `pt`/`pt_PT` (só `pt_BR`), pelo que
#     as suas mensagens saíam em INGLÊS (ex.: o erro de login);
#   * Django REST Framework — o catálogo efetivo é o `pt`, em português do
#     Brasil e com alguns erros gramaticais; reescrevemos em pt-PT as
#     mensagens que esta aplicação pode emitir.
#
# Como LOCALE_PATHS tem precedência sobre os catálogos das libs, estas
# entradas ganham. Os msgid TÊM de coincidir com o texto-fonte inglês exato
# da biblioteca — se uma atualização o mudar, a tradução deixa de aplicar-se
# (há testes que o detetam). Recompilar após editar:
#     python manage.py compilemessages_pure
msgid ""
msgstr ""
"Project-Id-Version: ForensiQ\n"
"Report-Msgid-Bugs-To: \n"
"MIME-Version: 1.0\n"
"Content-Type: text/plain; charset=UTF-8\n"
"Content-Transfer-Encoding: 8bit\n"
"Language: pt_PT\n"
"Plural-Forms: nplurals=2; plural=(n != 1);\n"

# =====================================================================
# rest_framework_simplejwt  (sem catálogo pt — sairiam em inglês)
# =====================================================================

# Erro de autenticação no login (POST /api/auth/login/).
msgid "No active account found with the given credentials"
msgstr "Credenciais inválidas. Verifique o utilizador e a palavra-passe."

msgid "No active account found for the given token."
msgstr "Não foi encontrada nenhuma conta ativa para o token indicado."

msgid "Token is invalid or expired"
msgstr "Sessão inválida ou expirada. Inicie sessão novamente."

msgid "Given token not valid for any token type"
msgstr "Token inválido."

msgid "Token is invalid"
msgstr "Token inválido."

msgid "Token is expired"
msgstr "Token expirado."

msgid "Token is blacklisted"
msgstr "Token revogado."

msgid "Token has no id"
msgstr "O token não tem identificador."

msgid "Token has no type"
msgstr "O token não tem tipo."

msgid "Token has wrong type"
msgstr "O token tem um tipo incorreto."

msgid "Token has no '{}' claim"
msgstr "O token não contém a reivindicação '{}'."

msgid "Token '{}' claim has expired"
msgstr "A reivindicação '{}' do token expirou."

msgid "Cannot create token with no type or lifetime"
msgstr "Não é possível criar um token sem tipo nem tempo de vida."

msgid "User not found"
msgstr "Utilizador não encontrado."

msgid "User is inactive"
msgstr "Utilizador inativo."

msgid "The user's password has been changed."
msgstr "A palavra-passe do utilizador foi alterada."

msgid "Token contained no recognizable user identification"
msgstr "O token não continha uma identificação de utilizador reconhecível."

msgid "Authorization header must contain two space-delimited values"
msgstr "O cabeçalho de autorização deve conter dois valores separados por espaço."

msgid "Invalid algorithm specified"
msgstr "Algoritmo inválido especificado."

# =====================================================================
# rest_framework  (catálogo efetivo `pt` é pt-BR e tem erros gramaticais)
# Reescrita em pt-PT das mensagens que esta aplicação pode emitir.
# =====================================================================

msgid "You do not have permission to perform this action."
msgstr "Não tem permissão para executar esta ação."

msgid "Authentication credentials were not provided."
msgstr "Não foram fornecidas credenciais de autenticação."

msgid "Incorrect authentication credentials."
msgstr "Credenciais de autenticação incorretas."

msgid "Request was throttled."
msgstr "Demasiados pedidos. Tente novamente mais tarde."

msgid "Expected available in {wait} second."
msgid_plural "Expected available in {wait} seconds."
msgstr[0] "Disponível dentro de {wait} segundo."
msgstr[1] "Disponível dentro de {wait} segundos."

# Validação de campos (DRF `pt` tem erros: género, espaço duplo, "devo",
# e "mais de" onde devia ser "pelo menos").
msgid "This field may not be blank."
msgstr "Este campo não pode ficar em branco."

msgid "\"{input}\" is not a valid choice."
msgstr "\"{input}\" não é uma opção válida."

msgid "A valid integer is required."
msgstr "É necessário um número inteiro válido."

msgid "A valid number is required."
msgstr "É necessário um número válido."

msgid "Must be a valid boolean."
msgstr "Tem de ser um valor booleano válido."

msgid "This field must be unique."
msgstr "Este campo tem de ser único."

msgid "The fields {field_names} must make a unique set."
msgstr "Os campos {field_names} têm de formar um conjunto único."

msgid "Ensure this field has no more than {max_length} characters."
msgstr "Garanta que este campo não tem mais do que {max_length} caracteres."

msgid "Ensure this field has at least {min_length} characters."
msgstr "Garanta que este campo tem pelo menos {min_length} caracteres."

msgid "Value must be valid JSON."
msgstr "O valor tem de ser JSON válido."

msgid "Expected a dictionary of items but got type \"{input_type}\"."
msgstr "Esperava um dicionário de itens mas recebeu o tipo \"{input_type}\"."

msgid "Expected a list of items but got type \"{input_type}\"."
msgstr "Esperava uma lista de itens mas recebeu o tipo \"{input_type}\"."

msgid "Invalid data. Expected a dictionary, but got {datatype}."
msgstr "Dados inválidos. Esperava um dicionário mas recebeu {datatype}."

# Upload de ficheiros/imagens (a app tem fotos de evidência) — DRF `pt`
# usa léxico pt-BR ("arquivo", "submetido").
msgid "No file was submitted."
msgstr "Não foi enviado nenhum ficheiro."

msgid "The submitted data was not a file. Check the encoding type on the form."
msgstr "Os dados enviados não são um ficheiro. Verifique o tipo de codificação do formulário."

msgid "The submitted file is empty."
msgstr "O ficheiro enviado está vazio."

msgid "No filename could be determined."
msgstr "Não foi possível determinar o nome do ficheiro."

msgid "Upload a valid image. The file you uploaded was either not an image or a corrupted image."
msgstr "Envie uma imagem válida. O ficheiro enviado não é uma imagem ou está corrompido."
