# ForensiQ — configuração de coverage (coverage.py).
#
# Executa:  coverage run --rcfile=.coveragerc manage.py test \
#               --settings=forensiq_project.test_settings
#           coverage report --rcfile=.coveragerc
#
# NOTA: ``fail_under`` em [report] é enforçado por ``coverage report``
# (mesmo sem flag CLI). Valor actual alinhado com a cobertura real
# (~68 %) mais uma margem mínima. Subir gradualmente com cada wave
# que adicionar testes.

[run]
branch = True
source = core, forensiq_project
parallel = False
omit =
    */migrations/*
    */tests.py
    */tests_*.py
    */__init__.py
    */apps.py
    */admin.py
    */wsgi.py
    */asgi.py
    */manage.py
    */test_settings.py
    */.venv/*
    */venv/*

[report]
# Limiar enforçado. Cobertura real ronda os 68 %. Subir conforme
# cada wave introduz testes; target final aspiracional 85 %.
fail_under = 65
show_missing = True
skip_covered = False
skip_empty = True
precision = 2
sort = Cover
exclude_lines =
    # Padrões standard — linhas que não contam para cobertura
    pragma: no cover
    def __repr__
    def __str__
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @(abc\.)?abstractmethod
    # Fallbacks de import opcionais (ex.: Pillow ausente)
    except ImportError:

[html]
directory = htmlcov
title = ForensiQ — Cobertura de Testes

[xml]
output = coverage.xml
