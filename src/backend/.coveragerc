# ForensiQ — configuração de coverage (coverage.py).
#
# Executa:  coverage run --rcfile=.coveragerc manage.py test \
#               --settings=forensiq_project.test_settings
#           coverage report --rcfile=.coveragerc
#
# NOTA: ``fail_under`` em [report] é enforçado por ``coverage report``
# (mesmo sem flag CLI). Alinhado com o gate único do projecto —
# ``pyproject.toml`` [tool.coverage.report], que o CI lê e enforça.
# A cobertura real (mesmo source + branch) ronda os ~84 %.

[run]
branch = True
source = core, forensiq_project
parallel = False
omit =
    */migrations/*
    */tests.py
    */tests_*.py
    */__init__.py
    */apps.py
    */admin.py
    */wsgi.py
    */asgi.py
    */manage.py
    */test_settings.py
    */.venv/*
    */venv/*

[report]
# Limiar enforçado, igual ao gate único em ``pyproject.toml``
# [tool.coverage.report] (lido pelo CI). Cobertura real ~84 %;
# target final aspiracional 85 %.
fail_under = 80
show_missing = True
skip_covered = False
skip_empty = True
precision = 2
sort = Cover
exclude_lines =
    # Padrões standard — linhas que não contam para cobertura
    pragma: no cover
    def __repr__
    def __str__
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @(abc\.)?abstractmethod
    # Fallbacks de import opcionais (ex.: Pillow ausente)
    except ImportError:

[html]
directory = htmlcov
title = ForensiQ — Cobertura de Testes

[xml]
output = coverage.xml
