digraph C4Container {
  rankdir=TB;
  bgcolor="transparent";
  graph [fontname="Helvetica", fontsize=12, nodesep=0.4, ranksep=0.7, compound=true];
  node  [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled", color="#9aa7b2", penwidth=1.1];
  edge  [fontname="Helvetica", fontsize=9, color="#5b6770"];

  User [label="Agente / Perito / Custódio / MP\n(browser — mobile/desktop)", fillcolor="#e8f0fe"];

  subgraph cluster_edge {
    label="Fly.io · Frankfurt"; style="rounded,dashed"; color="#2e7d32"; fontsize=11;
    Gunicorn [label="Gunicorn (WSGI) + WhiteNoise\nHTTPS A+ (Let's Encrypt) · HSTS preload", fillcolor="#eafaf0"];
  }

  subgraph cluster_app {
    label="Django 6.0 · forensiq_project (app core)"; style="rounded,filled"; color="#1565c0"; fillcolor="#f5f8ff"; fontsize=11;
    Templates [label="Frontend server-rendered\nTemplates Django + HTMX + Leaflet\ngerador único de grelha (core.grid)", fillcolor="#e8f0fe"];
    DRF       [label="API REST (DRF)\nViewSets + Serializers\nJWT cookies HttpOnly + CSRF", fillcolor="#e8f0fe"];
    MW        [label="Middleware\nCorrelationID · CSP nonce", fillcolor="#eef1f4"];
    Policy    [label="Camada de política (core/policy)\nevent_states · custody_transitions\n(pura, sem ORM — ADR-0019)", fillcolor="#fff6e6"];
    Access    [label="Acesso need-to-know (core/access)\npapéis + credencial + instituição\n(ADR-0017)", fillcolor="#fff6e6"];
    Models    [label="Modelos + triggers PG (append-only)\nEvidence (imutável) · ChainOfCustody (ledger)\nAuditLog · Institution · taxonomia de crimes\nSHA-256 encadeado (hv4) — ADR-0013/0015", fillcolor="#e8f0fe"];
    Cache     [label="DatabaseCache\nthrottle · lookups · stats", fillcolor="#eef1f4"];
    PDFGen    [label="PDF + QR (guia de transporte)\nReportLab + qrcode — ADR-0012", fillcolor="#e8f0fe"];
    Services  [label="Serviços externos\nimei_lookup · vin_lookup\nreverse-geocode · nearby-pois", fillcolor="#eef1f4"];
  }

  Neon   [label="PostgreSQL · Neon.tech\n(Frankfurt, PgBouncer, PITR 7d)", shape=cylinder, fillcolor="#eafaf0"];
  Volume [label="Fly Volume /data/media\nfotografias (EXIF removido)", shape=cylinder, fillcolor="#eafaf0"];
  OSM    [label="OpenStreetMap\nNominatim · Overpass · tiles", shape=parallelogram, fillcolor="#f3eafe"];
  IMEI   [label="IMEIDB.xyz", shape=parallelogram, fillcolor="#f3eafe"];
  VIN    [label="vindecoder.eu", shape=parallelogram, fillcolor="#f3eafe"];

  User -> Gunicorn [label="HTTPS"];
  Gunicorn -> Templates;
  Gunicorn -> DRF;
  Templates -> DRF [label="HTMX / fetch"];
  DRF -> MW;
  DRF -> Access;
  DRF -> Policy;
  MW -> Models;
  Access -> Models;
  Policy -> Models;
  Models -> Neon;
  DRF -> Cache -> Neon;
  DRF -> PDFGen;
  DRF -> Services;
  Services -> OSM [style=dashed, label="geocoding/POIs"];
  Services -> IMEI [style=dashed];
  Services -> VIN [style=dashed];
  PDFGen -> Volume [style=dashed, label="lê fotos"];
  Models -> Volume [style=dashed, label="grava fotos"];
}
